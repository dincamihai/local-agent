{
  "name": "local-agent",
  "version": "0.1.0",
  "description": "MCP bridge that delegates coding tasks to a local LLM (ollama) running in a Docker container with read/write/bash tools and long-term memory.",
  "main": "pi-bridge-mcp.ts",
  "type": "module",
  "scripts": {
    "test": "tsx queue.test.ts && tsx pi-bridge-mcp.test.ts && tsx membrain-extension.test.ts",
    "test:queue": "tsx queue.test.ts",
    "test:bridge": "tsx pi-bridge-mcp.test.ts",
    "test:extension": "tsx membrain-extension.test.ts"
  },
  "keywords": [
    "mcp",
    "llm",
    "ollama",
    "agent",
    "coding-agent",
    "claude"
  ],
  "author": "Mihai Dincă <dincamihai@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dincamihai/local-agent.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
